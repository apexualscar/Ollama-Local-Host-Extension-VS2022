<UserControl x:Class="OllamaLocalHostIntergration.Controls.ContextChipControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             toolkit:Themes.UseVsTheme="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OllamaLocalHostIntergration;component/Styles/CopilotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border x:Name="ChipBorder"
            Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMenuBackgroundGradientKey}}"
            BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="10,5,6,5"
            Margin="0,0,6,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Icon -->
            <TextBlock Grid.Column="0"
                       Text="{Binding Icon}"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="11"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.AccentMediumKey}}"/>
            
            <!-- Type Label -->
            <TextBlock Grid.Column="1"
                       FontSize="9"
                       FontWeight="Bold"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                       Opacity="0.7">
                <Run Text="["/><Run Text="{Binding TypeLabel, Mode=OneWay}"/><Run Text="]"/>
            </TextBlock>
            
            <!-- Display Text -->
            <TextBlock Grid.Column="2"
                       Text="{Binding DisplayText}"
                       FontSize="11"
                       MaxWidth="200"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            
            <!-- Remove Button -->
            <Button Grid.Column="3"
                    Content="&#xE711;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="8"
                    VerticalAlignment="Center"
                    ToolTip="Remove context"
                    Click="RemoveClick"
                    Style="{DynamicResource CopilotChipCloseButton}"/>
        </Grid>
    </Border>
</UserControl>
